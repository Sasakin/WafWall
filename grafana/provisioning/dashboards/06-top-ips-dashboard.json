{
  "dashboard": {
    "title": "WAF Top Attackers (ClickHouse)",
    "tags": ["waf", "top-ips", "clickhouse"],
    "timezone": "browser",
    "refresh": "5m",
    "panels": [
      {
        "id": 1,
        "title": "Top 10 Attacking IPs",
        "type": "table",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 10},
        "datasource": "ClickHouse",
        "options": {
          "showType": "top"
        },
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "blocked_count"},
              "properties": [{"id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 1000}]
              }}]
            }
          ]
        },
        "targets": [
          {
            "datasource": "ClickHouse",
            "rawSql": "SELECT source_ip, sum(blocked_count) as blocked_count, sum(total_requests) as total_requests, any(primary_threat) as primary_threat FROM security.hourly_top_ips WHERE ts_hour >= now() - INTERVAL 24 HOUR GROUP BY source_ip ORDER BY blocked_count DESC LIMIT 10"
          }
        ]
      },
      {
        "id": 2,
        "title": "Attacks by Country",
        "type": "geomap",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 10},
        "datasource": "ClickHouse",
        "options": {
          "basemap": {
            "type": "default"
          },
          "layers": []
        },
        "targets": [
          {
            "datasource": "ClickHouse",
            "rawSql": "SELECT country_code, sum(blocked_count) as blocked FROM security.hourly_stats_by_threat WHERE ts_hour >= now() - INTERVAL 24 HOUR AND country_code != '' GROUP BY country_code ORDER BY blocked DESC"
          }
        ]
      },
      {
        "id": 3,
        "title": "Top Countries by Blocked Requests",
        "type": "barchart",
        "gridPos": {"x": 0, "y": 10, "w": 12, "h": 8},
        "datasource": "ClickHouse",
        "options": {
          "legend": {"displayMode": "list", "placement": "bottom"},
          "orientation": "horizontal"
        },
        "targets": [
          {
            "datasource": "ClickHouse",
            "rawSql": "SELECT country_code, sum(blocked_count) as blocked FROM security.hourly_stats_by_threat WHERE ts_hour >= now() - INTERVAL 24 HOUR GROUP BY country_code ORDER BY blocked DESC LIMIT 15"
          }
        ]
      },
      {
        "id": 4,
        "title": "Attack Timeline by Top IPs",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 10, "w": 12, "h": 8},
        "datasource": "ClickHouse",
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "lines",
              "lineWidth": 2,
              "fillOpacity": 20
            }
          }
        },
        "targets": [
          {
            "datasource": "ClickHouse",
            "rawSql": "SELECT ts_hour, source_ip, sum(blocked_count) as blocked FROM security.hourly_top_ips WHERE ts_hour >= now() - INTERVAL 24 HOUR GROUP BY ts_hour, source_ip HAVING sum(blocked_count) > 50 ORDER BY ts_hour"
          }
        ]
      },
      {
        "id": 5,
        "title": "Rate Limit Hits by IP",
        "type": "table",
        "gridPos": {"x": 0, "y": 18, "w": 24, "h": 6},
        "datasource": "ClickHouse",
        "targets": [
          {
            "datasource": "ClickHouse",
            "rawSql": "SELECT source_ip, sum(rate_limit_hits) as rate_limit_hits FROM security.hourly_rate_limit_stats WHERE ts_hour >= now() - INTERVAL 24 HOUR GROUP BY source_ip ORDER BY rate_limit_hits DESC LIMIT 20"
          }
        ]
      }
    ],
    "schemaVersion": 38,
    "version": 1
  }
}
