{
  "dashboard": {
    "title": "WAF Security Dashboard",
    "tags": ["waf", "security"],
    "timezone": "browser",
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Total Requests (RPS)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(waf_requests_total[1m])",
            "legendFormat": "RPS"
          }
        ]
      },
      {
        "id": 2,
        "title": "Blocked Requests by Type",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(waf_blocked_total{threat_type=\"sql_injection\"}[1m])",
            "legendFormat": "SQL Injection"
          },
          {
            "expr": "rate(waf_blocked_total{threat_type=\"xss\"}[1m])",
            "legendFormat": "XSS"
          },
          {
            "expr": "rate(waf_blocked_total{threat_type=\"bot\"}[1m])",
            "legendFormat": "Bot"
          },
          {
            "expr": "rate(waf_blocked_total{threat_type=\"rate_limit\"}[1m])",
            "legendFormat": "Rate Limit"
          }
        ]
      },
      {
        "id": 3,
        "title": "Top Blocked IPs",
        "type": "table",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "topk(10, rate(waf_blocked_total[5m]))",
            "format": "table"
          }
        ]
      },
      {
        "id": 4,
        "title": "Request Latency (p50, p95, p99)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(waf_request_duration_seconds_bucket[1m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(waf_request_duration_seconds_bucket[1m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(waf_request_duration_seconds_bucket[1m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "id": 5,
        "title": "Allowed vs Blocked Requests",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(waf_requests_allowed_total[1m])",
            "legendFormat": "Allowed"
          },
          {
            "expr": "rate(waf_requests_blocked_total[1m])",
            "legendFormat": "Blocked"
          }
        ]
      },
      {
        "id": 6,
        "title": "Active Connections",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "waf_active_connections",
            "legendFormat": "Active"
          }
        ]
      }
    ],
    "version": 1
  }
}