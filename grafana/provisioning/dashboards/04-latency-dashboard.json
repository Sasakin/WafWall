{
  "title": "WAF - Latency",
  "tags": ["waf", "latency", "performance"],
  "timezone": "browser",
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Request Latency p50, p95, p99",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 16, "h": 10},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(waf_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(waf_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(waf_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 2,
      "title": "Average Latency",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 4},
      "targets": [
        {
          "expr": "rate(waf_request_duration_seconds_sum[1m]) / rate(waf_request_duration_seconds_count[1m])",
          "legendFormat": "avg ms"
        }
      ]
    }
  ],
  "version": 1
}