{
  "info": {
    "name": "WAF Gateway Tests",
    "description": "Коллекция для тестирования WAF Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Endpoint",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "Allowed Request",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.{{$randomInt}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test"]
            }
          }
        },
        {
          "name": "Rate Limit Exceeded",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "for (let i = 0; i < 100; i++) {",
                  "  pm.sendRequest({",
                  "    url: pm.variables.get('baseUrl') + '/api/test',",
                  "    method: 'GET',",
                  "    header: {",
                  "      key: 'X-Forwarded-For',",
                  "      value: '192.168.1.1'",
                  "    }",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "192.168.1.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test"]
            }
          }
        }
      ]
    },
    {
      "name": "SQL Injection Detection",
      "item": [
        {
          "name": "UNION SELECT",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users?id=1' UNION SELECT * FROM users--",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                {
                  "key": "id",
                  "value": "1' UNION SELECT * FROM users--"
                }
              ]
            }
          }
        },
        {
          "name": "OR 1=1",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/search?q=test' OR '1'='1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "test' OR '1'='1"
                }
              ]
            }
          }
        },
        {
          "name": "DROP TABLE",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/query?sql=DROP TABLE users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query"],
              "query": [
                {
                  "key": "sql",
                  "value": "DROP TABLE users"
                }
              ]
            }
          }
        },
        {
          "name": "DELETE Statement",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/item?id=1; DELETE FROM orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "item"],
              "query": [
                {
                  "key": "id",
                  "value": "1; DELETE FROM orders"
                }
              ]
            }
          }
        },
        {
          "name": "Comment Injection (--)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api?id=1--",
              "host": ["{{baseUrl}}"],
              "path": ["api"],
              "query": [
                {
                  "key": "id",
                  "value": "1--"
                }
              ]
            }
          }
        },
        {
          "name": "Comment Injection (/* */)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api?id=1/*comment*/",
              "host": ["{{baseUrl}}"],
              "path": ["api"],
              "query": [
                {
                  "key": "id",
                  "value": "1/*comment*/"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "XSS Detection",
      "item": [
        {
          "name": "Script Tag",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api?input=<script>alert(1)</script>",
              "host": ["{{baseUrl}}"],
              "path": ["api"],
              "query": [
                {
                  "key": "input",
                  "value": "<script>alert(1)</script>"
                }
              ]
            }
          }
        },
        {
          "name": "Image onerror",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/search?q=<img src=x onerror=alert(1)>",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "<img src=x onerror=alert(1)>"
                }
              ]
            }
          }
        },
        {
          "name": "SVG onload",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api?comment=<svg onload=alert(1)>",
              "host": ["{{baseUrl}}"],
              "path": ["api"],
              "query": [
                {
                  "key": "comment",
                  "value": "<svg onload=alert(1)>"
                }
              ]
            }
          }
        },
        {
          "name": "JavaScript URI",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api?url=javascript:alert(1)",
              "host": ["{{baseUrl}}"],
              "path": ["api"],
              "query": [
                {
                  "key": "url",
                  "value": "javascript:alert(1)"
                }
              ]
            }
          }
        },
        {
          "name": "Iframe javascript",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api?data=<iframe src=javascript:alert(1)>",
              "host": ["{{baseUrl}}"],
              "path": ["api"],
              "query": [
                {
                  "key": "data",
                  "value": "<iframe src=javascript:alert(1)>"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bot Detection",
      "item": [
        {
          "name": "Known Bot User-Agent (curl)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              },
              {
                "key": "User-Agent",
                "value": "curl/7.68.0"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test"]
            }
          }
        },
        {
          "name": "Known Bot User-Agent (python)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              },
              {
                "key": "User-Agent",
                "value": "python-requests/2.28.0"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test"]
            }
          }
        },
        {
          "name": "Empty User-Agent",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              },
              {
                "key": "User-Agent",
                "value": ""
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test"]
            }
          }
        },
        {
          "name": "Normal Browser User-Agent",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              },
              {
                "key": "User-Agent",
                "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
              },
              {
                "key": "Accept",
                "value": "text/html,application/xhtml+xml"
              },
              {
                "key": "Accept-Language",
                "value": "en-US,en;q=0.9"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test"]
            }
          }
        }
      ]
    },
    {
      "name": "Proxy Service",
      "item": [
        {
          "name": "Clean Request",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/proxy/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "proxy", "test"]
            }
          }
        },
        {
          "name": "With Query Params",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/proxy/test?param1=value1&param2=value2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "proxy", "test"],
              "query": [
                {
                  "key": "param1",
                  "value": "value1"
                },
                {
                  "key": "param2",
                  "value": "value2"
                }
              ]
            }
          }
        },
        {
          "name": "POST Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"key\": \"value\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/proxy/test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "proxy", "test"]
            }
          }
        }
      ]
    },
    {
      "name": "Metrics",
      "item": [
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["metrics"]
            }
          }
        },
        {
          "name": "Actuator Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Normal Requests (Should Pass)",
      "item": [
        {
          "name": "GET Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/123",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "123"]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Search Query",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "10.0.0.1"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/search?q=laptop",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "laptop"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}