FROM eclipse-temurin:17-jre-alpine

WORKDIR /app

COPY ./gateway/build/libs/gateway.jar app.jar

EXPOSE 8080

ENV JAVA_OPTS="-Xms512m -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=50 -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=50 -XX:+UseStringDeduplication -XX:+OptimizeStringConcat"

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]